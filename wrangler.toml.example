name = "web-message-board"
compatibility_date = "2024-01-01"

# Pages configuration
pages_build_output_dir = "./"

# Environment Variables Configuration
# For local development: Create .dev.vars file with ADMIN_SECRET_KEY=your-key
# For production: Set ADMIN_SECRET_KEY in Cloudflare Pages Dashboard > Settings > Environment Variables > Secrets
# The ADMIN_SECRET_KEY must be at least 32 characters for security

# KV namespace binding (for rate limiting)
[[kv_namespaces]]
binding = "RATE_LIMIT_KV"
id = "xxxx-xxxx-xxxx-xxxx-xxxx"

# Pages Functions configuration
[env.production]
vars = { ENVIRONMENT = "production" }

[[env.production.d1_databases]]
binding = "DB"
database_name = "issue-board-db"
database_id = "xxxx-xxxx-xxxx-xxxx-xxxx"

[[env.production.kv_namespaces]]
binding = "RATE_LIMIT_KV"
id = "xxxx-xxxx-xxxx-xxxx-xxxx"

[env.preview]
vars = { ENVIRONMENT = "preview" }
# Preview must use a different D1 database_id from production.

[[env.preview.d1_databases]]
binding = "DB"
database_name = "issue-board-db-preview"
database_id = "yyyy-yyyy-yyyy-yyyy-yyyy"

[[env.preview.kv_namespaces]]
binding = "RATE_LIMIT_KV"
id = "xxxx-xxxx-xxxx-xxxx-xxxx"
