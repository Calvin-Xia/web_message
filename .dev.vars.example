# Local development variables for Cloudflare Pages / Wrangler
# Copy this file to .dev.vars and fill in the real values.
# Do not commit .dev.vars.

# Shared admin bearer secret.
# Quote the value if it contains #, &, $, or spaces.
ADMIN_SECRET_KEY="your-secret-key-here-change-me"

# Optional explicit environment label for local development.
# The repository defaults to local in wrangler.toml, but keeping it here helps when debugging.
ENVIRONMENT="local"
